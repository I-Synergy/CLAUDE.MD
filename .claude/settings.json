{
  "plansDirectory": "./.ai/plans",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "dotnet build --nologo --verbosity quiet"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash",
      "Edit",
      "Write",
      "Read",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm -rf:*)"
    ],
    "additionalDirectories": [
      "./.claude",
      "./.ai",
      "./.ai/analysis",
      "./.ai/checklists",
      "./.ai/completed",
      "./.ai/patterns",
      "./.ai/plans",
      "./.ai/progress",
      "./.ai/project",
      "./.ai/reference",
      "./.ai/skills"
    ]
  }
}
